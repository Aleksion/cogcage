# Convex
CONVEX_DEPLOYMENT=dev:your-deployment
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Upstash Redis (durable storage — required for prod)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Monetization (set in Vercel dashboard)
PUBLIC_STRIPE_FOUNDER_URL=https://buy.stripe.com/your-link
COGCAGE_POSTBACK_KEY=your-secret-key
MOLTPIT_OPS_KEY=your-ops-key

# Feature flags
VITE_ENABLE_GUEST_AUTH=true
